{
  "name": "Pilotrix",
  "version": "2.0.0",
  "author": "Notewizard Team",
  "private": true,
  "type": "module",
  "description": "Pilotrix Installer",
  "main": "main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:preload": "vite build --config vite.preload.config.ts --watch",
    "dev:electron": "wait-on http://127.0.0.1:5173/ electron/preload/index.js && nodemon --watch electron --ext js,json --exec electron .",
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:preload\" \"npm:dev:electron\"",
    "start": "npm run build:preload && electron .",
    "build:preload": "vite build --config vite.preload.config.ts",
    "check:preload": "node scripts/check-preload.mjs",
    "smoke:electron": "node scripts/electron-smoke.mjs",
    "build": "npm run build:preload && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/lib-storage": "^3.1032.0",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@icon-park/vue-next": "^1.4.2",
    "@lancedb/lancedb": "^0.27.2",
    "apache-arrow": "^21.1.0",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.8.3",
    "markdown-it": "^14.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "webdav": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/eslint-config-typescript": "^14.2.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.1.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.app.pilotrix",
    "productName": "Pilotrix",
    "copyright": "Copyright © 2026 ${author}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "compression": "maximum",
    "publish": [
      {
        "provider": "github",
        "owner": "jetyu",
        "repo": "Pilotrix",
        "vPrefixedTagName": true
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Pilotrix-Windows-${arch}.${ext}",
      "icon": "electron/assets/logo/app-logo.ico",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Pilotrix-macOS-${arch}.${ext}",
      "icon": "electron/assets/logo/app-logo.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": null,
      "entitlementsInherit": null
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 400
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Pilotrix-Linux-${arch}.${ext}",
      "icon": "electron/assets/logo/app-logo-512.png",
      "category": "Office",
      "maintainer": "Pilotrix Team",
      "vendor": "Pilotrix",
      "synopsis": "A powerful note-taking application",
      "description": "Pilotrix is a modern, feature-rich note-taking application for organizing your thoughts and ideas."
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pilotrix",
      "uninstallDisplayName": "Pilotrix",
      "deleteAppDataOnUninstall": true
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "main.js",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/codemirror/**",
      "**/node_modules/lancedb/**",
      "**/node_modules/apache-arrow/**",
      "**/node_modules/markdown-it/**"
    ]
  }
}