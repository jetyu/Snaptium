{
  "name": "Pilotra",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Electron + Vue 3 + CodeMirror 6 + Markdown-It scaffold",
  "main": "main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:preload": "vite build --config vite.preload.config.ts --watch",
    "dev:electron": "wait-on http://127.0.0.1:5173/ electron/preload/index.js && nodemon --watch electron --ext js,json --exec electron .",
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:preload\" \"npm:dev:electron\"",
    "start": "npm run build:preload && electron .",
    "build:preload": "vite build --config vite.preload.config.ts",
    "check:preload": "node scripts/check-preload.mjs",
    "build": "npm run build:preload && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "markdown-it": "^14.1.0",
    "pinia": "^2.2.4",
    "sanitize-html": "^2.17.0",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.0",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/eslint-config-typescript": "^14.2.0",
    "concurrently": "^8.2.2",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.15.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.12.0",
    "nodemon": "^3.1.14",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vite": "^7.1.7",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.1.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.app.pilotra",
    "productName": "Pilotra",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "index.html",
      "vite.config.ts",
      "main.js",
      "package.json"
    ]
  }
}
