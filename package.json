{
  "name": "notewizard",
  "version": "1.1.0",
  "type": "module",
  "description": "NoteWizard Installer",
  "license": "MIT License",
  "author": "NoteWizard Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch main.js --watch src --exec electron .",
    "dist": "npm run sync:user-agreement && node build.js",
    "dist:win": "npm run sync:user-agreement && electron-builder --win --x64 --publish always",
    "dist:mac": "npm run sync:user-agreement && electron-builder --mac --x64 --arm64 --publish always",
    "dist:linux": "npm run sync:user-agreement && electron-builder --linux --publish always",
    "dist:all": "npm run sync:user-agreement && electron-builder -wml",
    "generate-icons": "node scripts/generate-icons.js",
    "clean": "rimraf dist",
    "sync:user-agreement": "node scripts/sync-terms-of-service.js"
  },
  "dependencies": {
    "@material-design-icons/svg": "^0.14.15",
    "adm-zip": "^0.5.10",
    "codemirror": "^5.65.20",
    "electron-updater": "^6.3.6",
    "icon-gen": "^5.0.0",
    "markdown-it": "^14.1.1",
    "mkdirp": "^3.0.1",
    "node-fetch": "^2.7.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^40.6.1",
    "electron-builder": "^26.7.0",
    "electron-reload": "^1.5.0",
    "nodemon": "^3.0.2",
    "rimraf": "^6.0.1"
  },
  "optionalDependencies": {
    "dmg-license": "^1.0.11"
  },
  "build": {
    "appId": "com.app.notewizard",
    "productName": "NoteWizard",
    "copyright": "Copyright © 2026 ${author}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "compression": "maximum",
    "publish": [
      {
        "provider": "github",
        "owner": "jetyu",
        "repo": "NoteWizard",
        "vPrefixedTagName": true
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NoteWizard-Windows-${arch}.${ext}",
      "icon": "src/assets/logo/app-logo.ico",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "NoteWizard-macOS-${arch}.${ext}",
      "icon": "src/assets/logo/app-logo.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": null,
      "entitlementsInherit": null
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 400
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NoteWizard-Linux-${arch}.${ext}",
      "icon": "src/assets/logo/app-logo-512.png",
      "category": "Office",
      "maintainer": "NoteWizard Team",
      "vendor": "NoteWizard",
      "synopsis": "A powerful note-taking application",
      "description": "NoteWizard is a modern, feature-rich note-taking application for organizing your thoughts and ideas."
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "license": "src/assets/terms-of-service/local-tos.txt",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NoteWizard",
      "uninstallDisplayName": "NoteWizard",
      "deleteAppDataOnUninstall": true,
      "include": "build/installer.nsh"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin",
      "!**/*.{o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/codemirror/**",
      "**/node_modules/markdown-it/**"
    ]
  }
}