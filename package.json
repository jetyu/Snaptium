{
  "name": "Snaptium",
  "version": "2.2.0",
  "author": "Snaptium Team",
  "private": true,
  "type": "module",
  "description": "Snaptium Installer",
  "main": ".electron-build/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:preload": "vite build --config vite.preload.config.ts --watch",
    "dev:electron": "wait-on http://127.0.0.1:5173/ && nodemon --watch electron --watch main.ts --watch preload.ts --watch tsconfig.electron.json --watch vite.preload.config.ts --ext ts,js,json --exec \"npm run build:main && npm run build:preload && electron .\"",
    "dev:winstore": "powershell -Command \"$env:SNAPTIUM_DISTRIBUTION='microsoft-store'; npm run dev\"",
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "start": "npm run build:main && npm run build:preload && electron .",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:preload": "vite build --config vite.preload.config.ts",
    "langcheck": "node src/scripts/check-locale-files.js",
    "build": "npm run build:main && npm run build:preload && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && node src/scripts/build-win.js",
    "dist:winstore": "npm run build && node src/scripts/build-win-store.js",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/lib-storage": "^3.1068.0",
    "@lancedb/lancedb": "^0.27.2",
    "@langchain/core": "^1.2.2",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/langgraph": "^1.4.8",
    "@langchain/ollama": "^1.3.0",
    "@langchain/openai": "^1.5.5",
    "@langchain/textsplitters": "^1.0.1",
    "@mdit/plugin-katex": "^0.25.2",
    "apache-arrow": "^18.1.0",
    "argon2": "^0.44.0",
    "electron-updater": "^6.8.9",
    "langchain": "^1.5.3",
    "webdav": "^5.10.0",
    "yarle-evernote-to-md": "^6.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.43.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tabler/icons-vue": "^3.44.0",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.21",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/eslint-config-typescript": "^14.8.0",
    "concurrently": "^10.0.3",
    "dompurify": "^3.4.12",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "markdown-it": "^14.2.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "nodemon": "^3.1.14",
    "pinia": "^3.0.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.5",
    "vue-tsc": "^2.1.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.app.snaptium",
    "productName": "Snaptium",
    "copyright": "Copyright © 2026 ${author}",
    "directories": {
      "output": "dist",
      "buildResources": "electron/assets"
    },
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://update.snaptium.com/download/latest"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Snaptium-Windows-${arch}.${ext}",
      "icon": "electron/assets/logo/app-logo.ico",
      "verifyUpdateCodeSignature": false
    },
    "appx": {
      "languages": [
        "de-DE",
        "en-US",
        "es-ES",
        "fr-FR",
        "id-ID",
        "it-IT",
        "ja-JP",
        "ko-KR",
        "pt-BR",
        "tr-TR",
        "zh-CN",
        "zh-HK",
        "zh-TW"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "Snaptium-macOS-${arch}.${ext}",
      "icon": "electron/assets/logo/app-logo.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": null,
      "entitlementsInherit": null
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 400
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Snaptium-Linux-${arch}.${ext}",
      "icon": "electron/assets/logo/app-logo-512.png",
      "category": "Office",
      "maintainer": "Snaptium Team",
      "vendor": "Snaptium",
      "synopsis": "A powerful note-taking application",
      "description": "Snaptium is a modern, feature-rich note-taking application for organizing your thoughts and ideas."
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Snaptium",
      "uninstallDisplayName": "Snaptium",
      "deleteAppDataOnUninstall": true
    },
    "files": [
      "dist/renderer/**/*",
      ".electron-build/**/*",
      "electron/assets/logo/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@lancedb/**/*.node",
      "**/node_modules/argon2/**/*.node"
    ],
    "extraResources": [
      {
        "from": "electron/assets/locales",
        "to": "assets/locales"
      }
    ]
  },
  "optionalDependencies": {
    "dmg-license": "^1.0.11"
  },
  "overrides": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "yarle-evernote-to-md": {
      "fast-xml-parser": "^5.9.3",
      "lodash": "^4.18.1",
      "nanoid": "^3.3.15",
      "utimes": {
        "@mapbox/node-pre-gyp": "^2.0.3"
      }
    }
  }
}
